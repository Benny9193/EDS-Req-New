# EDS Universal Requisition - Development Environment
# Copy to .env and customize for local development

# ===========================================
# Frontend Configuration
# ===========================================
FRONTEND_PORT=3000
API_BASE_URL=http://localhost:8000/api
BUDGET_LIMIT=5000

# ===========================================
# API Configuration
# ===========================================
API_PORT=8000
LOG_LEVEL=DEBUG

# ===========================================
# Database Configuration
# ===========================================
DB_SERVER=localhost
DB_DATABASE=EDS
DB_USERNAME=
DB_PASSWORD=
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERT=yes

# Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_CONNECTION_TIMEOUT=30
