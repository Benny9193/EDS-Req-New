# EDS Universal Requisition - Production Environment
# Copy to prod.env and set secure values
# NEVER commit prod.env to version control!

# ===========================================
# Frontend Configuration
# ===========================================
FRONTEND_PORT=80
API_BASE_URL=/api
BUDGET_LIMIT=5000

# ===========================================
# API Configuration
# ===========================================
API_PORT=8000
LOG_LEVEL=WARNING

# ===========================================
# Database Configuration
# ===========================================
# Set these securely - use secrets management in production
DB_SERVER=your-sql-server.database.windows.net
DB_DATABASE=EDS_Production
DB_USERNAME=eds_app_user
DB_PASSWORD=<SET_SECURE_PASSWORD>
DB_DRIVER=ODBC Driver 18 for SQL Server
DB_TRUST_CERT=no

# Connection Pool - Production settings
DB_POOL_MIN=5
DB_POOL_MAX=20
DB_CONNECTION_TIMEOUT=30
