# SQL Server Connection Settings
# Copy this file to .env and fill in your values

DB_SERVER=your-server.database.windows.net
DB_DATABASE=dpa_EDSAdmin
DB_USERNAME=your_username
DB_PASSWORD=your_password

# AI / LLM Provider Configuration
# Set LLM_PROVIDER to choose the AI backend: "claude", "ollama", or "openai"
# If omitted, auto-detects: uses "claude" when ANTHROPIC_API_KEY is set, "ollama" otherwise
LLM_PROVIDER=ollama

# For Claude provider (requires API key)
# ANTHROPIC_API_KEY=sk-ant-...

# For Ollama provider (runs locally, no API key needed)
# Install: https://ollama.ai  |  Run: ollama pull qwen2.5:14b && ollama serve
# OLLAMA_HOST=http://localhost:11434

# Elasticsearch Configuration
# Uses the existing EDS-ES Azure VM by default
# ES_ENABLED=true                          # Enabled by default
# ES_URL=http://20.122.81.233:9200         # EDS-ES VM (Azure, eastus2)
# ES_INDEX=pricing_consolidated_51          # Production pricing index
